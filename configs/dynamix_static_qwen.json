{
  "scenario": "static_build",
  "output_dir": "runs/dynamix_static_qwen/tree",
  "records_path": "runs/dynamix_static_qwen/records.json",
  "dataset_path": "data/spreadsheetbench_verified/spreadsheetbench_verified_400",
  "train_start": 0,
  "train_end": 200,
  "enforce_dataset_order": true,
  "generation": {
    "base_url": "http://10.26.1.21:18002/v1",
    "model": "Qwen3.5-9B",
    "api_key": "EMPTY",
    "temperature": 0.6,
    "timeout_seconds": 1200,
    "max_concurrency": 8,
    "thinking_mode": true,
    "extra_body": {
      "chat_template_kwargs": {
        "enable_thinking": true
      }
    }
  },
  "embedding": {
    "base_url": "http://10.26.1.184:18007/v1",
    "model": "Qwen3-Embedding-8B",
    "api_key": "EMPTY",
    "max_model_len": 32000,
    "max_input_tokens": 32000,
    "truncate_long_texts": true,
    "batch_size": 8,
    "max_concurrency": 8,
    "cache_path": "runs/cache/qwen3_embedding_8b_cache.sqlite",
    "tokenizer_model": "/mnt/data/grouph_share/models/modelscope/models/Qwen/Qwen3-Embedding-8B",
    "tokenizer_required": true,
    "truncation_strategy": "head"
  },
  "chunked_embedding": {
    "enabled": true,
    "chunk_tokens": 8000,
    "overlap_tokens": 1000,
    "pooling": "mean",
    "add_special_tokens": false,
    "normalize_after_pooling": false,
    "fail_if_chunk_exceeds_model_limit": true
  },
  "hierarchy": {
    "projection": {
      "method": "local_pca",
      "variance_ratio": 0.9,
      "max_dim": 32,
      "min_dim": 2,
      "whiten": false
    },
    "gmm_bic": {
      "covariance_type": "spherical",
      "num_restarts": 5,
      "kmeans_init_iters": 15,
      "max_iter": 100,
      "tol": 0.0001,
      "min_covar": 1e-06,
      "min_split_size": 2,
      "min_effective_samples_per_component": 2,
      "abs_kmax": 64,
      "max_concurrent_candidates": 1,
      "max_concurrent_restarts": 1
    },
    "soft_membership": {
      "save_soft_edges": true,
      "recursive_assignment": "cumulative_mass",
      "cumulative_mass_coverage": 0.9
    },
    "budget_refinement": {
      "enabled": true,
      "apply_to_level": 0,
      "selection_policy": "bic_best_with_token_progress",
      "min_token_reduction_fraction": 0.1,
      "fallback": "gmm_bic_recursive",
      "flatten_refinement_leaves_to_l0": true,
      "skip_oversize_singleton": true
    },
    "summary_budget": {
      "max_model_tokens": 100000,
      "budget_ratio": 0.85,
      "prompt_overhead_reserve_tokens": 8000
    },
    "random_seed": 42
  },
  "analyst": {
    "prompt_style": "trace2skill_cluster_level_v2",
    "confidence_floor": 0.05
  },
  "max_levels": 8,
  "skill_output_dir_name": "skills"
}
